{
  "tasks": {
    "dev": "deno run -A --watch=static/,routes/ dev.ts",
    "dev:agent": "GARAZYK_DASHBOARD_AGENT_LAUNCH=1 deno run -A --watch=static/,routes/ dev.ts",
    "build": "deno run -A dev.ts build",
    "start": "deno run -A main.ts",
    "preview": "deno run -A main.ts",
    "tui": "deno run -A tui.ts",
    "tui:record": "GARAZYK_TUI_RECORD=1 deno run -A tui.ts",
    "export-run": "deno run -A export_run.ts",
    "tui:capture": "deno run -A tui_headless_capture.ts"
  },
  "imports": {
    "@garazyk/tui": "../../packages/tui/mod.ts",
    "@garazyk/tui/testing": "../../packages/tui/testing/mod.ts",
    "@std/assert": "jsr:@std/assert@0.224.0",
    "$fresh/": "https://deno.land/x/fresh@1.7.3/",
    "preact": "https://esm.sh/preact@10.22.0",
    "preact/": "https://esm.sh/preact@10.22.0/",
    "@preact/signals": "https://esm.sh/*@preact/signals@1.2.3",
    "@preact/signals-core": "https://esm.sh/*@preact/signals-core@1.5.1",
    "tailwindcss": "npm:tailwindcss@3.4.7",
    "tailwindcss/": "npm:/tailwindcss@3.4.7/",
    "tailwindcss/plugin": "npm:tailwindcss@3.4.7/plugin.js",
    "$std/": "https://deno.land/std@0.224.0/",
    "sqlite3": "https://deno.land/x/sqlite3@0.12.0/mod.ts",
    "ansi_up": "https://esm.sh/ansi_up@6.0.2"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  }
}
