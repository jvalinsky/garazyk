{
  "tasks": {
    "doc-lint": "deno doc --lint lib/deno/mod.ts",
    "doc": "deno doc --lint lib/deno/mod.ts",
    "doc:serve": "deno doc --html --name='Garazyk Test Harness' lib/deno/mod.ts && open docs/index.html",
    "doc:objc": "bash docs/generate-api-docs.sh",
    "doc:objc:mcss": "bash docs/generate-api-docs.sh --mcss",
    "doc:objc:serve": "bash docs/generate-api-docs.sh --serve",
    "doc:objc:clean": "bash docs/generate-api-docs.sh --clean",
    "doc:coverage": "deno run -A docs/doc-coverage.ts ../Garazyk/Sources --min-overall 100 --min-subsystem Core=100 --min-subsystem Other=100 --min-subsystem AppView=100 --min-subsystem Services=100 --min-subsystem AdminUIServer=100 --min-subsystem Chat=100 --min-subsystem Database=100 --min-subsystem Blob=100",
    "doc:ts-coverage": "deno run -A docs/tsdoc-coverage.ts lib/deno scenario-dashboard",
    "doc:ts-coverage:ci": "deno run -A docs/tsdoc-coverage.ts lib/deno --min-overall 65",
    "run-scenarios": "deno run -A run_scenarios.ts",
    "mock-twilio": "deno run -A mock-twilio-server.ts",
    "test": "deno test -A --doc lib/deno/mod.ts",
    "test:mock-twilio": "deno test -A mock-twilio-server.test.ts"
  },
  "imports": {
    "@atproto/api": "npm:@atproto/api@^0.13.0",
    "@ipld/car": "npm:@ipld/car@^5.3.1",
    "@ipld/dag-cbor": "npm:@ipld/dag-cbor@^9.0.6",
    "@std/assert": "jsr:@std/assert@1",
    "@std/cli": "jsr:@std/cli@1",
    "@std/fmt": "jsr:@std/fmt@1",
    "@std/fs": "jsr:@std/fs@1",
    "@std/path": "jsr:@std/path@1",
    "zod": "npm:zod@3.25.76"
  },
  "fmt": {
    "lineWidth": 100
  },
  "nodeModulesDir": "auto"
}
