{
  "name": "tranquil-pds",
  "description": "Tranquil PDS (Rust) with Garazyk Relay, PLC, and AppView. Tests Rust PDS interop.",
  "roles": {
    "plc": { "inherit": "garazyk-default" },
    "pds": {
      "name": "tranquil-pds",
      "image": "ghcr.io/likeco/tranquil-pds:latest",
      "command": ["serve", "--port", "2583"],
      "env": {
        "TRANQUIL_PDS_HOSTNAME": "localhost",
        "TRANQUIL_PDS_PLC_URL": "http://local-plc:2582",
        "TRANQUIL_PDS_DATA_DIR": "/data"
      },
      "ports": ["2583:2583"],
      "volumes": ["tranquil_pds_data:/data"],
      "healthCheck": {
        "path": "/xrpc/com.atproto.server.describeServer"
      },
      "capabilities": [
        "describeServer", "createAccount", "createSession", "getSession",
        "createRecord", "getRecord", "deleteRecord", "listRecords",
        "uploadBlob", "getBlob",
        "resolveHandle", "updateHandle",
        "subscribeRepos", "getHead", "getRepo", "requestCrawl",
        "repo", "identity", "blob", "sync"
      ],
      "dependsOn": ["local-plc"]
    },
    "relay": { "inherit": "garazyk-default" },
    "appview": { "inherit": "garazyk-default" }
  }
}
