{
  "name": "indigo-tap",
  "description": "Indigo Tap (Go, bluesky-social) with Garazyk PDS, Relay, and PLC. Standalone sync utility that handles firehose consumption, verification, backfill, and filtered output. Applications connect to Tap instead of directly to the relay.",
  "roles": {
    "plc": { "inherit": "garazyk-default" },
    "pds": { "inherit": "garazyk-default" },
    "pds2": { "inherit": "garazyk-default" },
    "relay": { "inherit": "garazyk-default" },
    "appview": { "inherit": "garazyk-default" },
    "backfill": {
      "name": "indigo-tap",
      "source": {
        "repo": "https://github.com/bluesky-social/indigo.git",
        "ref": "main",
        "dockerDir": "cmd/tap"
      },
      "env": {
        "TAP_RELAY_URL": "http://local-relay:2584",
        "TAP_PLC_URL": "http://local-plc:2582",
        "TAP_BIND": ":2480",
        "TAP_DATABASE_URL": "sqlite:///data/tap.db",
        "TAP_DISABLE_ACKS": "true",
        "TAP_NO_REPLAY": "true"
      },
      "ports": ["2480:2480"],
      "volumes": ["tap_data:/data"],
      "healthCheck": {
        "path": "/health"
      },
      "capabilities": [
        "backfill",
        "filteredSync",
        "repoVerification",
        "webhookDelivery",
        "collectionFiltering",
        "perRepoOrdering",
        "identityCaching"
      ],
      "dependsOn": ["local-relay"]
    }
  }
}
