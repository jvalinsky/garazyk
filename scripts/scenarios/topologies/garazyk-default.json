{
  "name": "garazyk-default",
  "description": "Full Garazyk stack: PDS (kaszlak), Relay (zuk), PLC (campagnola), AppView (syrena), Mikrus, Beskid, Chat (syrena-chat), Video (jelcz), UI (garazyk-ui). Built from local source.",
  "roles": {
    "plc": {
      "name": "campagnola",
      "buildContext": "docker/local-network",
      "dockerfile": "Dockerfile.local",
      "entrypoint": ["/usr/local/bin/campagnola"],
      "command": [
        "serve",
        "--host",
        "0.0.0.0",
        "--port",
        "2582",
        "--database",
        "/var/lib/atprotopds/plc.db"
      ],
      "env": {
        "TZ": "UTC",
        "PLC_HOURLY_LIMIT": "500",
        "PLC_DAILY_LIMIT": "1000",
        "PLC_WEEKLY_LIMIT": "5000"
      },
      "ports": ["2582:2582"],
      "volumes": ["local_plc_data:/var/lib/atprotopds"],
      "healthCheck": {
        "path": "/_health"
      },
      "capabilities": [
        "createAccount",
        "didResolution",
        "operationLog",
        "handleRotation",
        "quotaEnforcement"
      ],
      "dependsOn": []
    },
    "pds": {
      "name": "kaszlak",
      "buildContext": "docker/local-network",
      "dockerfile": "Dockerfile.local",
      "command": [
        "serve",
        "--config",
        "/var/lib/atprotopds/config.json",
        "--foreground"
      ],
      "env": {
        "TZ": "UTC",
        "PDS_ALLOW_PRIVATE_SSRF": "1",
        "PDS_ALLOW_HTTP": "1",
        "PDS_LEXICON_PATH": "/usr/share/atprotopds/lexicons",
        "HOME": "/var/lib/atprotopds",
        "PDS_RATELIMIT_ENABLED": "false",
        "PDS_HANDLE_RESOLVE_LIMIT": "10000",
        "PDS_DATA_DIR": "/var/lib/atprotopds",
        "PDS_PLC_KEYS_DIR": "/var/lib/atprotopds/keys",
        "PDS_MASTER_SECRET": "32107992c973da8445b485263cb2bd3157859cb94294a2355e3c4a7b0f825afe",
        "GARAZYK_ALLOW_PRIVATE_OAUTH_CLIENTS": "1",
        "PDS_RUNNING_TESTS": "1",
        "PDS_USE_KEYCHAIN": "false",
        "PDS_ADMIN_PASSWORD": "admin-localdev",
        "PDS_FIREHOSE_MAX_PENDING_SENDS": "1",
        "PDS_FIREHOSE_MAX_PENDING_BYTES": "10000"
      },
      "ports": ["2583:2583"],
      "volumes": [
        "local_pds_data:/var/lib/atprotopds",
        "./pds-config.json:/var/lib/atprotopds/config.json:ro",
        "local_pds_keys:/var/lib/atprotopds/keys"
      ],
      "healthCheck": {
        "path": "/xrpc/com.atproto.server.describeServer"
      },
      "capabilities": [
        "describeServer",
        "createAccount",
        "createSession",
        "getSession",
        "createRecord",
        "getRecord",
        "deleteRecord",
        "listRecords",
        "uploadBlob",
        "getBlob",
        "listBlobs",
        "resolveHandle",
        "updateHandle",
        "requestPlcOperationSignature",
        "signPlcOperation",
        "subscribeRepos",
        "getHead",
        "getRepo",
        "requestCrawl",
        "admin",
        "moderation",
        "labeling",
        "repo",
        "identity",
        "blob",
        "sync"
      ],
      "dependsOn": ["local-plc"]
    },
    "pds2": {
      "name": "kaszlak-pds2",
      "buildContext": "docker/local-network",
      "dockerfile": "Dockerfile.local",
      "command": [
        "serve",
        "--config",
        "/var/lib/atprotopds/config.json",
        "--foreground"
      ],
      "env": {
        "TZ": "UTC",
        "PDS_ALLOW_PRIVATE_SSRF": "1",
        "PDS_ALLOW_HTTP": "1",
        "PDS_LEXICON_PATH": "/usr/share/atprotopds/lexicons",
        "HOME": "/var/lib/atprotopds",
        "PDS_RATELIMIT_ENABLED": "false",
        "PDS_HANDLE_RESOLVE_LIMIT": "10000",
        "PDS_DATA_DIR": "/var/lib/atprotopds",
        "PDS_PLC_KEYS_DIR": "/var/lib/atprotopds/keys",
        "PDS_MASTER_SECRET": "32107992c973da8445b485263cb2bd3157859cb94294a2355e3c4a7b0f825afe",
        "GARAZYK_ALLOW_PRIVATE_OAUTH_CLIENTS": "1",
        "PDS_RUNNING_TESTS": "1",
        "PDS_USE_KEYCHAIN": "false",
        "PDS_ADMIN_PASSWORD": "admin-localdev",
        "PDS_FIREHOSE_MAX_PENDING_SENDS": "1",
        "PDS_FIREHOSE_MAX_PENDING_BYTES": "10000"
      },
      "ports": ["2587:2587"],
      "volumes": [
        "local_pds2_data:/var/lib/atprotopds",
        "./pds2-config.json:/var/lib/atprotopds/config.json:ro",
        "local_pds2_keys:/var/lib/atprotopds/keys"
      ],
      "healthCheck": {
        "path": "/xrpc/com.atproto.server.describeServer"
      },
      "capabilities": [
        "describeServer",
        "createAccount",
        "createSession",
        "getSession",
        "createRecord",
        "getRecord",
        "deleteRecord",
        "listRecords",
        "uploadBlob",
        "getBlob",
        "listBlobs",
        "resolveHandle",
        "updateHandle",
        "requestPlcOperationSignature",
        "signPlcOperation",
        "subscribeRepos",
        "getHead",
        "getRepo",
        "requestCrawl",
        "admin",
        "moderation",
        "labeling",
        "repo",
        "identity",
        "blob",
        "sync"
      ],
      "dependsOn": ["local-plc"]
    },
    "pds3": {
      "name": "kaszlak-pds3",
      "buildContext": "docker/local-network",
      "dockerfile": "Dockerfile.local",
      "command": [
        "serve",
        "--config",
        "/var/lib/atprotopds/config.json",
        "--foreground"
      ],
      "env": {
        "TZ": "UTC",
        "PDS_ALLOW_PRIVATE_SSRF": "1",
        "PDS_ALLOW_HTTP": "1",
        "PDS_LEXICON_PATH": "/usr/share/atprotopds/lexicons",
        "HOME": "/var/lib/atprotopds",
        "PDS_RATELIMIT_ENABLED": "false",
        "PDS_HANDLE_RESOLVE_LIMIT": "10000",
        "PDS_DATA_DIR": "/var/lib/atprotopds",
        "PDS_PLC_KEYS_DIR": "/var/lib/atprotopds/keys",
        "PDS_MASTER_SECRET": "32107992c973da8445b485263cb2bd3157859cb94294a2355e3c4a7b0f825afe",
        "GARAZYK_ALLOW_PRIVATE_OAUTH_CLIENTS": "1",
        "PDS_RUNNING_TESTS": "1",
        "PDS_USE_KEYCHAIN": "false",
        "PDS_ADMIN_PASSWORD": "admin-localdev",
        "PDS_FIREHOSE_MAX_PENDING_SENDS": "1",
        "PDS_FIREHOSE_MAX_PENDING_BYTES": "10000"
      },
      "ports": ["2588:2585"],
      "volumes": [
        "local_pds3_data:/var/lib/atprotopds",
        "./pds3-config.json:/var/lib/atprotopds/config.json:ro",
        "local_pds3_keys:/var/lib/atprotopds/keys"
      ],
      "healthCheck": {
        "path": "/xrpc/com.atproto.server.describeServer"
      },
      "capabilities": [
        "describeServer",
        "createAccount",
        "createSession",
        "getSession",
        "createRecord",
        "getRecord",
        "deleteRecord",
        "listRecords",
        "uploadBlob",
        "getBlob",
        "listBlobs",
        "resolveHandle",
        "updateHandle",
        "requestPlcOperationSignature",
        "signPlcOperation",
        "subscribeRepos",
        "getHead",
        "getRepo",
        "requestCrawl",
        "admin",
        "moderation",
        "labeling",
        "repo",
        "identity",
        "blob",
        "sync"
      ],
      "dependsOn": ["local-plc"]
    },
    "relay": {
      "name": "zuk",
      "buildContext": "docker/local-network",
      "dockerfile": "Dockerfile.local",
      "entrypoint": ["/usr/local/bin/zuk"],
      "command": [
        "serve",
        "--upstream",
        "ws://local-pds:2583/xrpc/com.atproto.sync.subscribeRepos",
        "--port",
        "2584",
        "--data-dir",
        "/var/lib/atprotopds"
      ],
      "env": {
        "TZ": "UTC",
        "PDS_ALLOW_PRIVATE_SSRF": "1",
        "PDS_ALLOW_HTTP": "1",
        "PDS_LEXICON_PATH": "/usr/share/atprotopds/lexicons"
      },
      "ports": ["2584:2584"],
      "volumes": ["local_relay_data:/var/lib/atprotopds"],
      "healthCheck": {
        "path": "/api/relay/health"
      },
      "capabilities": [
        "subscribeRepos",
        "requestCrawl",
        "healthCheck",
        "upstreams"
      ],
      "dependsOn": ["local-pds"]
    },
    "appview": {
      "name": "syrena",
      "buildContext": "docker/local-network",
      "dockerfile": "Dockerfile.local",
      "entrypoint": ["/usr/local/bin/syrena"],
      "command": [
        "serve",
        "--relay",
        "ws://local-relay:2584",
        "--port",
        "3200",
        "--data-dir",
        "/var/lib/atprotopds",
        "--no-backfill"
      ],
      "env": {
        "TZ": "UTC",
        "PDS_ALLOW_PRIVATE_SSRF": "1",
        "PDS_ALLOW_HTTP": "1",
        "PDS_LEXICON_PATH": "/usr/share/atprotopds/lexicons",
        "PDS_WRITE_PROXY_OVERRIDE": "http://local-pds:2583",
        "APPVIEW_ADMIN_SECRET": "localdevadmin",
        "APPVIEW_DATA_DIR": "/var/lib/atprotopds",
        "APPVIEW_PLC_URL": "http://local-plc:2582",
        "APPVIEW_PDS_URL": "http://local-pds:2583",
        "APPVIEW_HTTP_PORT": "3200"
      },
      "ports": ["3200:3200"],
      "volumes": ["local_appview_data:/var/lib/atprotopds"],
      "healthCheck": {
        "path": "/admin/backfill/status",
        "headers": { "Authorization": "Bearer localdevadmin" }
      },
      "capabilities": [
        "getTimeline",
        "getProfile",
        "getFeed",
        "search",
        "backfill",
        "admin"
      ],
      "dependsOn": ["local-relay"]
    },
    "mikrus": {
      "name": "mikrus",
      "buildContext": "docker/local-network",
      "dockerfile": "Dockerfile.local",
      "entrypoint": ["/usr/local/bin/mikrus"],
      "command": [
        "serve",
        "--relay",
        "ws://local-pds:2583",
        "--port",
        "3210",
        "--data-dir",
        "/var/lib/atprotopds"
      ],
      "env": {
        "TZ": "UTC",
        "PDS_ALLOW_PRIVATE_SSRF": "1",
        "PDS_ALLOW_HTTP": "1",
        "PDS_PLC_URL": "http://local-plc:2582",
        "MIKRUS_PDS_URL": "http://local-pds:2583",
        "MIKRUS_RELAY_URLS": "ws://local-pds:2583",
        "MIKRUS_DATA_DIR": "/var/lib/atprotopds",
        "MIKRUS_HTTP_PORT": "3210",
        "MIKRUS_RATELIMIT_ENABLED": "true",
        "MIKRUS_RATELIMIT_IP_LIMIT": "200",
        "MIKRUS_RATELIMIT_IP_WINDOW": "60"
      },
      "ports": ["3210:3210"],
      "volumes": ["local_mikrus_data:/var/lib/atprotopds"],
      "healthCheck": {
        "path": "/_health"
      },
      "capabilities": [
        "firehoseIndexing",
        "getBacklinks",
        "getBacklinkDids",
        "getBacklinksCount",
        "getManyToMany",
        "getManyToManyCounts",
        "getRecordByUri",
        "resolveMiniDoc"
      ],
      "dependsOn": ["local-relay"]
    },
    "beskid": {
      "name": "beskid",
      "buildContext": "docker/local-network",
      "dockerfile": "Dockerfile.local",
      "entrypoint": ["/usr/local/bin/beskid"],
      "command": [
        "serve",
        "--port",
        "8085",
        "--data-dir",
        "/var/lib/atprotopds"
      ],
      "env": {
        "TZ": "UTC",
        "PDS_ALLOW_PRIVATE_SSRF": "1",
        "PDS_ALLOW_HTTP": "1",
        "PDS_PLC_URL": "http://local-plc:2582",
        "PLC_URL": "http://local-plc:2582",
        "BESKID_PDS_URL": "http://local-pds:2583",
        "BESKID_DATA_DIR": "/var/lib/atprotopds",
        "BESKID_HTTP_PORT": "8085",
        "BESKID_CACHE_RECORD_TTL": "3600",
        "BESKID_CACHE_IDENTITY_TTL": "86400",
        "BESKID_RATELIMIT_ENABLED": "true",
        "BESKID_RATELIMIT_IP_LIMIT": "200",
        "BESKID_RATELIMIT_IP_WINDOW": "60"
      },
      "ports": ["8085:8085"],
      "volumes": ["local_beskid_data:/var/lib/atprotopds"],
      "healthCheck": {
        "path": "/_health"
      },
      "capabilities": [
        "getRecord",
        "getUriRecord",
        "getRecordByUri",
        "resolveHandle",
        "resolveMiniDoc",
        "resolveService",
        "hydrateQueryResponse",
        "recordCache",
        "identityCache"
      ],
      "dependsOn": ["local-pds", "local-plc"]
    },
    "chat": {
      "name": "syrena-chat",
      "buildContext": "docker/local-network",
      "dockerfile": "Dockerfile.local",
      "entrypoint": ["/usr/local/bin/syrena-chat"],
      "command": [
        "serve",
        "--port",
        "2585",
        "--data-dir",
        "/var/lib/atprotopds"
      ],
      "env": {
        "TZ": "UTC",
        "CHAT_PDS_URL": "http://local-pds:2583",
        "CHAT_PLC_URL": "http://local-plc:2582"
      },
      "ports": ["2585:2585"],
      "volumes": ["local_chat_data:/var/lib/atprotopds"],
      "healthCheck": {
        "path": "/_health"
      },
      "capabilities": ["dm", "chat", "healthCheck"],
      "dependsOn": ["local-pds"]
    },
    "video": {
      "name": "jelcz",
      "buildContext": "docker/local-network",
      "dockerfile": "Dockerfile.local",
      "entrypoint": ["/usr/local/bin/jelcz"],
      "command": ["serve", "--port", "2586"],
      "env": {
        "TZ": "UTC",
        "JELCZ_PDS_URL": "http://local-pds:2583",
        "JELCZ_PLC_URL": "http://local-plc:2582",
        "JELCZ_DATA_DIR": "/var/lib/atprotopds"
      },
      "ports": ["2586:2586"],
      "volumes": ["local_video_data:/var/lib/atprotopds"],
      "healthCheck": {
        "path": "/_health"
      },
      "capabilities": ["uploadVideo", "getVideoStatus", "healthCheck"],
      "dependsOn": ["local-pds"]
    },
    "ui": {
      "name": "garazyk-ui",
      "buildContext": "docker/local-network",
      "dockerfile": "Dockerfile.local",
      "entrypoint": ["/usr/local/bin/garazyk-ui"],
      "command": [
        "serve",
        "--host",
        "0.0.0.0",
        "--port",
        "2590"
      ],
      "env": {
        "TZ": "UTC",
        "GARAZYK_UI_PORT": "2590",
        "GARAZYK_UI_ADMIN_PASSWORD": "admin-localdev",
        "GARAZYK_UI_PDS_URL": "http://local-pds:2583",
        "GARAZYK_UI_PDS_PASSWORD": "admin-localdev",
        "GARAZYK_UI_PLC_URL": "http://local-plc:2582",
        "GARAZYK_UI_RELAY_URL": "http://local-relay:2584",
        "GARAZYK_UI_APPVIEW_URL": "http://local-appview:3200",
        "GARAZYK_UI_APPVIEW_TOKEN": "localdevadmin",
        "GARAZYK_UI_CHAT_URL": "http://local-chat:2585",
        "GARAZYK_UI_VIDEO_URL": "http://local-video:2586"
      },
      "ports": ["2590:2590"],
      "healthCheck": {
        "path": "/lab"
      },
      "capabilities": ["admin", "login", "oauth", "smoke"],
      "dependsOn": ["local-pds", "local-appview"],
      "scenarioEnv": {
        "GARAZYK_UI_ADMIN_PASSWORD": "admin-localdev"
      }
    }
  },
  "networkAliases": {
    "local-appview": ["bsky.app"]
  }
}
