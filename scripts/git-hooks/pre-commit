#!/usr/bin/env bash
# pre-commit hook: reject commits that contain likely secrets.
# Install: cp scripts/git-hooks/pre-commit .git/hooks/pre-commit
#
# Checks staged files for patterns that look like real secrets.
# Local-dev defaults (password123, admin-localdev, etc.) are allowed
# in docker/ and scripts/ directories.

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[0;33m'
NC='\033[0m' # No Color

# Patterns that indicate a real secret (not a local-dev placeholder).
# 64-char hex strings are typical for PDS_MASTER_SECRET, JWT_SECRET, etc.
REAL_SECRET_PATTERNS=(
  'PDS_MASTER_SECRET=[0-9a-f]{40,}'
  'JWT_SECRET=[0-9a-f]{40,}'
  'ADMIN_PASSWORD=[0-9a-f]{20,}'
  'ENCRYPTION_KEY=[0-9a-f]{20,}'
  'SIGNING_KEY=[0-9a-f]{20,}'
  # 64-char hex in config files (not docker local-dev)
  '"master_secret":\s*"[0-9a-f]{64}"'
)

# Known local-dev values that are acceptable
LOCAL_DEV_SECRETS=(
  '32107992c973da8445b485263cb2bd3157859cb94294a2355e3c4a7b0f825afe'
  '7ba3e8f1c092da445b485263cb2bd3157859cb94294a2355e3c4a7b0f825aff'
  'admin-localdev'
  'password123'
  'testpass123'
)

found_secrets=0

# Get list of staged files (skip deleted files)
staged_files=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

if [ -z "$staged_files" ]; then
  exit 0
fi

for file in $staged_files; do
  # Skip binary files (check first 8KB for null bytes)
  if grep -Pqm1 '\x00' "$file" 2>/dev/null; then
    continue
  fi

  # Get the staged content
  content=$(git show ":$file" 2>/dev/null || true)
  if [ -z "$content" ]; then
    continue
  fi

  # Check for real secret patterns
  for pattern in "${REAL_SECRET_PATTERNS[@]}"; do
    matches=$(echo "$content" | grep -nE "$pattern" 2>/dev/null || true)
    if [ -n "$matches" ]; then
      # Filter out known local-dev values
      for dev_secret in "${LOCAL_DEV_SECRETS[@]}"; do
        matches=$(echo "$matches" | grep -v "$dev_secret" 2>/dev/null || true)
      done

      if [ -n "$matches" ]; then
        echo -e "${RED}SECRET DETECTED${NC} in ${file}:"
        echo "$matches" | head -5
        echo ""
        found_secrets=1
      fi
    fi
  done
done

if [ $found_secrets -ne 0 ]; then
  echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo -e "${RED}COMMIT REJECTED: Potential secrets detected in staged files.${NC}"
  echo -e "${YELLOW}If this is a false positive, commit with --no-verify.${NC}"
  echo -e "${YELLOW}If this is a real secret, use environment variables instead.${NC}"
  echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  exit 1
fi

exit 0
