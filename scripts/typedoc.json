    "packages/laweta/mod.ts",
    "packages/laweta/docker_compose.ts",
    "packages/hamownia/mod.ts",
    "packages/hamownia/atproto_network.ts",
    "packages/hamownia/binary_services.ts",
    "packages/hamownia/stale_cleanup.ts",
    "packages/hamownia/docker_runner.ts",
    "packages/hamownia/run_command.ts",
    "packages/schemat/mod.ts",
    "packages/schemat/runtime.ts",
