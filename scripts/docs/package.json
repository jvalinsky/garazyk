{
  "name": "garazyk-docs-tooling",
  "version": "1.0.0",
  "description": "Documentation consolidation and validation tooling for Garazyk",
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "node --test",
    "migrate": "node migrate.js",
    "validate": "node validate.js",
    "validate-config": "node validate-config.js",
    "archive": "node archive.js",
    "repo:sync": "deno run -A ../../scripts/docs/repo_docs.ts sync",
    "repo:related": "deno run -A ../../scripts/docs/repo_docs.ts enrich-related",
    "repo:validate:strict": "deno run -A ../../scripts/docs/repo_docs.ts validate --internal-strict --orphans",
    "repo:validate:external": "deno run -A ../../scripts/docs/repo_docs.ts validate --external-report",
    "api:ts": "cd .. && typedoc --options typedoc.json"
  },
  "keywords": [
    "documentation",
    "migration",
    "validation",
    "atproto"
  ],
  "author": "Garazyk Contributors",
  "license": "MIT",
  "dependencies": {
    "fs-extra": "^11.2.0",
    "glob": "^10.3.10",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "marked": "^11.1.1",
    "minimatch": "^10.2.2"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^10.6.1",
    "eslint": "^8.56.0",
    "typedoc": "^0.28.14",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
