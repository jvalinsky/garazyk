    "glob": "^10.3.10",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "marked": "^11.1.1",
    "minimatch": "^10.2.2"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^10.6.1",
    "eslint": "^8.56.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
