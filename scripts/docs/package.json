{
  "name": "atprotopds-docs-tooling",
  "version": "1.0.0",
  "description": "Documentation consolidation and validation tooling for ATProtoPDS",
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "node --test",
    "migrate": "node migrate.js",
    "validate": "node validate.js",
    "validate-config": "node validate-config.js",
    "archive": "node archive.js"
