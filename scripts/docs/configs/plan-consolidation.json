{
  "version": "1.0.0",
  "description": "Consolidate documentation from plan/ and plans/ directories into docs/plans/",
  "migrations": [
    {
      "source": "plan",
      "destination": "docs/plans",
      "filePatterns": [
        "**/*.md",
        "**/*.txt",
        "**/*.json"
      ],
      "excludePatterns": [
        "**/.git/**",
        "**/node_modules/**",
        "**/.DS_Store",
        "**/Thumbs.db",
        "**/*.swp",
        "**/*~"
      ],
      "preserveStructure": true,
      "updateReferences": true,
      "removeEmptyDirs": true
    },
    {
      "source": "plans",
      "destination": "docs/plans",
      "filePatterns": [
        "**/*.md",
        "**/*.txt",
        "**/*.json"
      ],
      "excludePatterns": [
        "**/.git/**",
        "**/node_modules/**",
        "**/.DS_Store",
        "**/Thumbs.db",
        "**/*.swp",
        "**/*~"
      ],
      "preserveStructure": true,
      "updateReferences": true,
      "removeEmptyDirs": true
    }
  ],
  "options": {
    "dryRun": false,
    "verbose": true,
    "generateReport": true,
    "reportPath": "docs/migration-report.json",
    "mappingPath": "docs/migration-mapping.json",
    "continueOnError": false
  }
}
