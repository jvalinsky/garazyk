{
  "name": "september-pds-docs",
  "version": "1.0.0",
  "description": "September PDS Documentation - Comprehensive guide for implementing an ATProto Personal Data Server in Objective-C",
  "type": "module",
  "scripts": {
    "docs:dev": "vitepress dev",
    "docs:build": "vitepress build",
    "docs:preview": "vitepress preview",
    "validate:links": "tsx scripts/validate-docs.ts --links",
    "validate:diagrams": "tsx scripts/validate-docs.ts --diagrams",
    "validate:code-blocks": "tsx scripts/validate-docs.ts --code-blocks",
    "validate:code-enhancements": "tsx scripts/validate-code-enhancements.ts",
    "validate:search-navigation": "tsx scripts/validate-search-navigation.ts",
    "validate:all": "tsx scripts/validate-docs.ts --all",
    "test:properties": "tsx scripts/property-based-tests.ts",
    "test:links": "tsx scripts/comprehensive-link-validation.ts",
    "test:accessibility": "tsx scripts/accessibility-validation.ts",
    "test:performance": "tsx scripts/performance-validation.ts",
    "test:code-examples": "tsx scripts/validate-code-examples.ts",
    "test:migration": "tsx scripts/migration-verification.ts",
    "test:all": "npm run test:properties && npm run test:links",
    "report:final": "tsx scripts/generate-final-report.ts"
  },
  "keywords": [
    "atproto",
    "pds",
    "documentation",
    "vitepress",
    "objective-c"
  ],
  "author": "September PDS Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.19.35",
    "@types/puppeteer": "^5.4.7",
    "axe-core": "^4.11.1",
    "fast-check": "^4.5.3",
    "glob": "^13.0.6",
    "markdown-it-container": "^4.0.0",
    "puppeteer": "^24.37.5",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitepress": "^1.0.0",
    "vue": "^3.4.0"
  }
}
