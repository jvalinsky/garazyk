+    /// Ensure the bucket exists. Creates it if it doesn't.
+    /// Idempotent — returns Ok if the bucket already exists.
+    /// This is needed for local testing with MinIO, which doesn't
+    /// auto-create buckets on put_object like some S3 implementations.
+    pub async fn ensure_bucket(&self) -> Result<()> {
+        self.bucket_created.get_or_try_init(|| async {
+            match self.client.create_bucket()
+                .bucket(&self.bucket)
+                .create_bucket_configuration(
+                    CreateBucketConfiguration::builder()
+                        .location_constraint(BucketLocationConstraint::UsEast1)
+                        .build()
+                )
+                .send()
+                .await
+            {
+                Ok(_) => Ok(()),
+                Err(s3::error::SdkError::ServiceError(e)) => {
+                    // BucketAlreadyOwnedByYou or BucketAlreadyExists — both are fine
+                    let code = e.raw().code().unwrap_or("Unknown");
+                    if code == "BucketAlreadyOwnedByYou" || code == "BucketAlreadyExists" {
+                        Ok(())
+                    } else {
+                        Err(anyhow::anyhow!("create_bucket failed: {}", code))
+                    }
+                }
+                Err(e) => Err(anyhow::anyhow!("create_bucket failed: {}", e)),
+            }
+        }).await?;
+        Ok(())
+    }
