{
  "server": {
    "host": "0.0.0.0",
    "port": 2583,
    "data_dir": "/var/lib/atprotopds",
    "issuer": "http://localhost:2583",
    "available_user_domains": [
      "localhost"
    ]
  },
  "appview": {
    "url": "http://local-appview:3200",
    "did": "did:web:local-appview",
    "local_enabled": true
  },
  "database": {
    "service_pool_max_size": 10,
    "user_pool_max_size": 50
  },
  "logging": {
    "format": "text",
    "level": "debug"
  },
  "session": {
    "access_token_ttl_seconds": 1800,
    "refresh_token_ttl_seconds": 2592000,
    "invite_code_required": false
  },
  "links": {
    "privacy_policy": "http://localhost:2583/privacy",
    "terms_of_service": "http://localhost:2583/terms"
  },
  "relays": [
    "http://local-relay:2584"
  ],
  "plc": {
    "url": "http://local-plc:2582",
    "retry_count": 3,
    "retry_delay_ms": 1000
  },
  "cors": {
    "allowed_origins": [
      "*"
    ],
    "allowed_methods": [
      "GET",
      "POST",
      "PUT",
      "DELETE",
      "OPTIONS",
      "HEAD"
    ],
    "allowed_headers": [
      "DPoP",
      "Authorization",
      "Content-Type",
      "*"
    ],
    "max_age": 86400
  },
  "rate_limit": {
    "enabled": false
  },
  "debug": {
    "skip_plc_operations": false
  }
}
