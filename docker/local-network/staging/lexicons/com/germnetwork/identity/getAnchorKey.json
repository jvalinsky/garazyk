{
  "lexicon": 1,
  "id": "com.germnetwork.identity.getAnchorKey",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get the current anchor key for a DID. Returns the TypedKeyMaterial wire format of the most recent com.germnetwork.declaration record. Models after Germ's current shipping 1:1 E2EE DM product.",
      "parameters": {
        "type": "object",
        "required": ["did"],
        "properties": {
          "did": {
            "type": "string",
            "description": "ATProto DID to look up",
            "minLength": 1,
            "maxLength": 512
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["anchorKey"],
          "properties": {
            "anchorKey": {
              "type": "bytes",
              "description": "TypedKeyMaterial wire format of the current anchor key"
            },
            "algorithm": {
              "type": "string",
              "description": "Algorithm identifier (e.g. 'curve25519Signing')",
              "enum": ["curve25519Signing"]
            },
            "keyHistory": {
              "type": "array",
              "items": {
                "type": "bytes"
              },
              "description": "Full anchor key history (TypedKeyMaterial wire formats, oldest first)"
            }
          }
        }
      }
    }
  }
}
