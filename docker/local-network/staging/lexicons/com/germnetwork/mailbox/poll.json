{
  "lexicon": 1,
  "id": "com.germnetwork.mailbox.poll",
  "defs": {
    "main": {
      "type": "query",
      "description": "Poll pending E2EE ciphertexts for an agent's mailbox addresses. Messages are deleted after polling (single-read semantics). The server cannot decrypt the ciphertexts. Models after Germ's current shipping 1:1 E2EE DM product.",
      "parameters": {
        "type": "object",
        "required": ["agentRef"],
        "properties": {
          "agentRef": {
            "type": "string",
            "description": "Opaque agent reference to poll for",
            "minLength": 1,
            "maxLength": 256
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["messages"],
          "properties": {
            "messages": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "#message"
              },
              "description": "Array of pending ciphertext messages"
            }
          }
        }
      }
    },
    "message": {
      "type": "object",
      "required": ["address", "ciphertext"],
      "properties": {
        "address": {
          "type": "string",
          "description": "Mailbox address this message was delivered to"
        },
        "ciphertext": {
          "type": "bytes",
          "description": "E2EE ciphertext blob"
        }
      }
    }
  }
}
