{
  "lexicon": 1,
  "id": "tools.garazyk.sync.getRepoFiltered",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get a verifiable CAR export containing only records from the specified collections.",
      "parameters": {
        "type": "params",
        "required": ["did", "collections"],
        "properties": {
          "did": { "type": "string", "format": "did", "description": "The DID of the repo." },
          "collections": {
            "type": "array",
            "description": "List of collection NSIDs to include.",
            "items": { "type": "string", "format": "nsid" },
            "minLength": 1
          },
          "since": {
            "type": "string",
            "description": "Optional revision cursor for incremental sync."
          }
        }
      },
      "output": {
        "encoding": "application/vnd.ipld.car"
      }
    }
  }
}
