{
  "lexicon": 1,
  "id": "tools.ozone.moderation.cancelScheduledAction",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Cancel a single scheduled moderation action by ID.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["id"],
          "properties": {
            "id": {
              "type": "string",
              "description": "The ID of the scheduled action to cancel"
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["success"],
          "properties": {
            "success": { "type": "boolean" }
          }
        }
      }
    }
  }
}
