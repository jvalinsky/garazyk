Name: gnustep-base
Description: The GNUstep Base Library is a library of general-purpose, non-graphical Objective C objects.
Version: 1.31.1
URL: https://github.com/gnustep/libs-base/
Libs: -L/usr/GNUstep/Local/Library/Libraries -L/usr/GNUstep/Local/lib -pthread -fexceptions -rdynamic -fobjc-runtime=gnustep-2.2 -fblocks -L/root/GNUstep/Library/Libraries -L/usr/GNUstep/Local/Library/Libraries -L/usr/GNUstep/System/Library/Libraries -lpthread -lobjc -lm
Cflags: -MMD -MP -DGNUSTEP_RUNTIME=1 -D_NONFRAGILE_ABI=1 -DGNUSTEP_BASE_LIBRARY=1 -fno-strict-aliasing -fexceptions -fobjc-exceptions -D_NATIVE_OBJC_EXCEPTIONS -pthread -fPIC -Wall -DGSWARN -DGSDIAGNOSE -Wno-import -g -O2 -fobjc-runtime=gnustep-2.2 -fblocks -I. -I/root/GNUstep/Library/Headers -I/usr/GNUstep/Local/Library/Headers -I/usr/GNUstep/System/Library/Headers
