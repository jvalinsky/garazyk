prefix=/usr/GNUstep/Local
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include

Name: libobjc
Description: GNUstep Objective-C runtime library
Version: 2.2.0

Cflags: -I${includedir}
Libs: -L${libdir} -lobjc
Libs.private: -lstdc++ -lm -lgcc_s -lgcc -lc -l/usr/lib/aarch64-linux-gnu/libm.so
