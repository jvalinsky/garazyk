diff --git a/rsky-relay/src/config.rs b/rsky-relay/src/config.rs
index 0000000..1111111 100644
--- a/rsky-relay/src/config.rs
+++ b/rsky-relay/src/config.rs
@@ -37,6 +37,12 @@ pub static HOSTS_RELAYS: LazyLock<Vec<String>> = LazyLock::new(|| {
         |s| s.split(',').map(str::trim).filter(|s| !s.is_empty()).map(str::to_owned).collect(),
     )
 });
+pub static CRAWL_SCHEME: LazyLock<String> = LazyLock::new(|| {
+    env::var("RELAY_CRAWL_SCHEME")
+        .ok()
+        .filter(|s| !s.is_empty())
+        .unwrap_or_else(|| "wss".to_owned())
+});
 pub const HOSTS_INTERVAL: Duration = Duration::from_secs(60 * 5);
 pub const HOSTS_MIN_ACCOUNTS: u64 = 0;

