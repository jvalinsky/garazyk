{
  "server": {
    "host": "0.0.0.0",
    "port": 2583,
    "data_dir": "/var/lib/atprotopds",
    "issuer": "https://pds.garazyk.xyz",
    "available_user_domains": [
      "garazyk.xyz"
    ]
  },
  "appview": {
    "url": "https://api.bsky.app",
    "did": "did:web:api.bsky.app",
    "local_enabled": false
  },
  "database": {
    "service_pool_max_size": 10,
    "user_pool_max_size": 50
  },
  "logging": {
    "format": "text",
    "level": "debug"
  },
  "session": {
    "access_token_ttl_seconds": 1800,
    "refresh_token_ttl_seconds": 2592000,
    "invite_code_required": false
  },
  "links": {
    "privacy_policy": "https://garazyk.xyz/privacy",
    "terms_of_service": "https://garazyk.xyz/terms"
  },
  "relays": [
    "http://e2e-relay:2584"
  ],
  "plc": {
    "url": "http://e2e-plc:2580",
    "retry_count": 3,
    "retry_delay_ms": 1000
  },
  "cors": {
    "allowed_origins": [
      "*"
    ],
    "allowed_methods": [
      "GET",
      "POST",
      "PUT",
      "DELETE",
      "OPTIONS",
      "HEAD"
    ],
    "allowed_headers": [
      "DPoP",
      "Authorization",
      "Content-Type",
      "*"
    ],
    "max_age": 86400
  },
  "rate_limit": {
    "enabled": false
  }
}
