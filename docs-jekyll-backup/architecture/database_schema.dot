strict digraph DatabaseSchema {
    rankdir=TB;
    node [shape=record, fontname="Helvetica"];
    edge [fontname="Helvetica"];

    account [label="{account|+ did: PK\n|+ handle: unique\n|+ email: unique\n|+ passwordHash\n|+ jwtPublicKey\n|+ jwtSecret\n|+ accessJwt\n|+ refreshJwt\n|+ sessionId\n|+ totpSecret\n|+ webAuthnCounter\n|+ createdAt\n|+ updatedAt}"];
    
    repo [label="{repo|+ did: PK, FK\n|+ rootCid\n|+ dataCid\n|+ mimeType\n|+ size}"];
    
    record [label="{record|+ uri: PK\n|+ did: FK\n|+ collection: FK\n|+ rkey\n|+ cid: FK\n|+ rawJson\n|+ indexedAt}"];
    
    blob [label="{blob|+ cid: PK, FK\n|+ mimeType\n|+ size\n|+ width\n|+ height\n|+ createdAt}"];
    
    block [label="{block|+ cid: PK\n|+ data\n|+ size\n|+ contentType}"];
    
    collection [label="{collection|+ id: PK\n|+ did: FK\n|+ name\n|+ type\n|+ description\n|+ createdAt}"];
    
    record_key [label="{record_key|+ id: PK\n|+ collection: FK\n|+ rkey: unique\n|+ nextRkey}"];
    
    subscription [label="{subscription|+ id: PK\n|+ did: FK\n|+ cursor\n|+ lastEventCid\n|+ createdAt}"];
    
    // Relationships
    account -> repo [label="1:N"];
    account -> collection [label="1:N"];
    account -> subscription [label="1:N"];
    repo -> block [label="1:N"];
    repo -> record [label="1:N"];
    collection -> record [label="1:N"];
    record -> block [label="N:1"];
    blob -> block [label="1:1"];
    record -> record_key [label="1:1"];
}
