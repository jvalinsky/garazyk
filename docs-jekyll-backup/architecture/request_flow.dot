strict digraph RequestFlow {
    rankdir=LR;
    node [shape=box, style=filled, fontname="Helvetica"];
    edge [fontname="Helvetica"];

    // Color coding: HTTP=lightblue, Auth=yellow, DB=lightgreen, Repo=lightpink
    subgraph cluster_http {
        label="HTTP Layer";
        color=lightblue;
        HttpServer [label="HttpServer\n(Listen on port 2583)"];
        RouteHandler [label="Route Matching"];
        XrpcDispatcher [label="XrpcHandler\n(NSID-based routing)"];
    }
    
    subgraph cluster_auth {
        label="Authentication";
        color=yellow;
        AuthMiddleware [label="Auth Middleware"];
        JWTValidator [label="JWT Validation\n(RS256/ES256)"];
        SessionManager [label="Session Manager"];
    }
    
    subgraph cluster_controller {
        label="Controller";
        color=lightcoral;
        PDSController [label="PDSController\n(God class)"];
    }
    
    subgraph cluster_services {
        label="Services";
        color=lightgreen;
        AccountService [label="AccountService"];
        RecordService [label="RecordService"];
        BlobService [label="BlobService"];
        RepoService [label="RepositoryService"];
        AdminService [label="AdminService"];
    }
    
    subgraph cluster_database {
        label="Database";
        color=lightyellow;
        DBPool [label="Connection Pool"];
        PDSDatabase [label="PDSDatabase"];
        ActorStore [label="ActorStore"];
    }
    
    subgraph cluster_repository {
        label="Repository Engine";
        color=lavender;
        MST [label="MST\n(Merkle Search Tree)"];
        CAR [label="CAR Archive"];
        CBOR [label="CBOR Encoder/Decoder"];
        Repo [label="Repository"];
    }
    
    // Flow edges
    HttpServer -> RouteHandler -> XrpcDispatcher;
    XrpcDispatcher -> AuthMiddleware -> JWTValidator -> SessionManager;
    AuthMiddleware -> PDSController [label="Validated DID"];
    
    PDSController -> AccountService;
    PDSController -> RecordService;
    PDSController -> BlobService;
    PDSController -> RepoService;
    PDSController -> AdminService;
    
    AccountService -> DBPool;
    RecordService -> DBPool;
    BlobService -> DBPool;
    RepoService -> DBPool;
    AdminService -> DBPool;
    
    DBPool -> PDSDatabase;
    PDSDatabase -> ActorStore;
    
    RecordService -> Repo -> MST;
    RecordService -> Repo -> CAR;
    RecordService -> Repo -> CBOR;
    BlobService -> Repo -> MST;
    BlobService -> Repo -> CBOR;
}
