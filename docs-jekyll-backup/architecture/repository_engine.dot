strict digraph RepositoryEngine {
    rankdir=TB;
    node [shape=box, style=filled, fontname="Helvetica"];
    edge [fontname="Helvetica"];

    subgraph cluster_repo_concept {
        label="Repository (User Data Store)";
        color=black;
        
        UserRepo [label="Repository\n(User DID + Data)", shape=ellipse, color=lightblue];
    }
    
    subgraph cluster_mst {
        label="MST - Merkle Search Tree";
        color=lightgreen;
        
        MST [label="MST\n(Balanced Tree Structure)"];
        MSTNode [label="MST Node\n(Hash + Sorted Links)"];
        MSTLeaf [label="MST Leaf\n(Key → CID mappings)"];
        MSTInternal [label="MST Internal\n(Non-leaf nodes)"];
        RootCID [label="Root CID\n(Content-addressable)"];
        
        MST -> MSTNode;
        MSTNode -> MSTLeaf;
        MSTNode -> MSTInternal;
        MSTInternal -> RootCID;
    }
    
    subgraph cluster_car {
        label="CAR - Content Addressable Records";
        color=lightyellow;
        
        CAR [label="CAR Archive\n(Binary format)"];
        Header [label="CAR Header\n(Version, roots)"];
        BlockSection [label="Block Section\n(CID + CBOR data)"];
        Payload [label="Payload\n(Records + Blocks)"];
        
        CAR -> Header;
        Header -> BlockSection;
        BlockSection -> Payload;
    }
    
    subgraph cluster_data_model {
        label="Data Model";
        color=lavender;
        
        RecordData [label="Record\n(ATURI, JSON/CBOR)"];
        BlobData [label="Blob\n(Binary data, CID)"];
        CollectionData [label="Collection\n(Named record group)"];
        KeyData [label="Record Key (rkey)\n(Unique per collection)"];
        
        RecordData -> BlobData;
        RecordData -> CollectionData;
        CollectionData -> KeyData;
    }
    
    subgraph cluster_operations {
        label="Repository Operations";
        color=lightpink;
        
        CreateRepo [label="Create Repository"];
        GetRecord [label="Get Record\n(MST → CID → Block)"];
        PutRecord [label="Put Record\n(MST update + CAR export)"];
        DeleteRecord [label="Delete Record\n(MST prune)"];
        ExportRepo [label="Export CAR\n(Snapshot)"];
        ImportRepo [label="Import CAR\n(Sync)"];
        
        CreateRepo -> GetRecord;
        GetRecord -> PutRecord;
        PutRecord -> DeleteRecord;
        DeleteRecord -> ExportRepo;
        ExportRepo -> ImportRepo;
    }
    
    // Connections
    UserRepo -> MST;
    UserRepo -> CAR;
    UserRepo -> RecordData;
    
    MST -> GetRecord;
    MST -> PutRecord;
    MST -> DeleteRecord;
    
    CAR -> ExportRepo;
    CAR -> ImportRepo;
}
