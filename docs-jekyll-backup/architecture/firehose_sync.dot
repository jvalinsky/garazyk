strict digraph FirehoseSync {
    rankdir=TB;
    node [shape=box, style=filled, fontname="Helvetica"];
    edge [fontname="Helvetica"];

    subgraph cluster_sources {
        label="Event Sources";
        color=lightblue;
        
        LocalWrite [label="Local Write\n(Record update)"];
        ImportCAR [label="Import CAR\n(Federation sync)"];
        AdminAction [label="Admin Action\n(Moderation)"];
    }
    
    subgraph cluster_firehose {
        label="Firehose (WebSocket Stream)";
        color=lightgreen;
        
        SubscribeHandler [label="SubscribeReposHandler"];
        EventEncoder [label="Event Encoder\n(CBOR/JSON)"];
        StreamManager [label="Stream Manager\n(Connection state)"];
        CursorManager [label="Cursor Manager\n(Event positions)"];
    }
    
    subgraph cluster_subscribers {
        label="Subscribers";
        color=lightyellow;
        
        AppView [label="AppView Bsky\n(Feed, Notifications)"];
        RelayPDS [label="Relay PDS\n(Federation)"];
        ThirdParty [label="Third Party\n(Apps, services)"];
    }
    
    subgraph cluster_sync_operations {
        label="Sync Operations";
        color=lavender;
        
        CreateCommit [label="Create Commit\n(Signed repo update)"];
        CreateHandle [label="Create Handle\n(Handle update)"];
        CreateAccount [label="Create Account\n(Account creation)"];
        Tombstone [label="Tombstone\n(Record deletion)"];
        
        CreateCommit -> CreateHandle;
        CreateHandle -> CreateAccount;
        CreateAccount -> Tombstone;
    }
    
    subgraph cluster_replication {
        label="Replication & Federation";
        color=lightpink;
        
        RelayService [label="Relay Service\n(PDS-to-PDS)"];
        RepoState [label="Repo State\n(Root CID tracking)"];
        ConflictResolver [label="Conflict Resolution"];
        
        RelayService -> RepoState;
        RepoState -> ConflictResolver;
    }
    
    // Flow
    LocalWrite -> SubscribeHandler;
    ImportCAR -> SubscribeHandler;
    AdminAction -> SubscribeHandler;
    
    SubscribeHandler -> EventEncoder;
    EventEncoder -> StreamManager;
    StreamManager -> CursorManager;
    
    CursorManager -> AppView;
    CursorManager -> RelayPDS;
    CursorManager -> ThirdParty;
    
    // Sync connections
    LocalWrite -> CreateCommit;
    CreateCommit -> RelayService;
    RelayService -> RepoState;
}
