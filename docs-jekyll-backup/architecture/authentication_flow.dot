strict digraph AuthFlow {
    rankdir=TB;
    node [shape=box, style=filled, fontname="Helvetica"];
    edge [fontname="Helvetica"];

    subgraph cluster_auth_flow {
        label="Authentication Flow";
        color=black;
        
        // Entry
        Client [label="Client App", shape=ellipse, color=lightblue];
        
        // Credentials
        Credentials [label="Credentials\n(Handle/DID + Password)", shape=parallelogram, color=lightyellow];
        
        // Auth Components
        AuthController [label="AuthController", color=lightcoral];
        KeyManager [label="KeyManager\n(Key Storage)", color=lightgreen];
        JWT [label="JWT\n(RS256/ES256)", color=lightblue];
        TOTP [label="TOTP\n(2FA)", color=lightpink];
        WebAuthn [label="WebAuthn\n(Passkeys)", color=lavender];
        OAuth2 [label="OAuth2\n(Authorization)", color=lemonchiffon];
        SessionDB [label="Session Store\n(Database)", color=lightgray];
        
        // Outputs
        AccessToken [label="Access Token\n(Short-lived)", shape=parallelogram, color=lightyellow];
        RefreshToken [label="Refresh Token\n(Long-lived)", shape=parallelogram, color=lightyellow];
        DIDToken [label="DID Token\n(Signed)", shape=parallelogram, color=lightyellow];
        
        // Auth chain
        Client -> Credentials -> AuthController;
        
        AuthController -> KeyManager [label="Get public key"];
        AuthController -> JWT [label="Sign/Verify"];
        AuthController -> TOTP [label="Verify code"];
        AuthController -> WebAuthn [label="Verify assertion"];
        AuthController -> OAuth2 [label="Authorization"];
        AuthController -> SessionDB [label="Store session"];
        
        AuthController -> AccessToken [label="JWT signed"];
        AuthController -> RefreshToken [label="Encrypted JWT"];
        AuthController -> DIDToken [label="DID document signed"];
    }
    
    subgraph cluster_token_validation {
        label="Token Validation";
        color=gray;
        
        ValidateAccess [label="Validate Access Token\n(Verify signature, expiry)"];
        ValidateRefresh [label="Validate Refresh Token\n(Decrypt, verify)"];
        ValidateDID [label="Validate DID Token\n(Verify DID, check revocation)"];
        
        ValidateAccess -> ValidateRefresh;
        ValidateRefresh -> ValidateDID;
    }
    
    // Validation flow
    AccessToken -> ValidateAccess;
    RefreshToken -> ValidateRefresh;
    DIDToken -> ValidateDID;
}
