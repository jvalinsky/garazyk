{
  "name": "@garazyk/dashboard",
  "version": "0.1.0-alpha.1",
  "description": "Fresh web dashboard and terminal UI for Garazyk scenario runs.",
  "exports": {
    ".": "./mod.ts",
    "./cli": "./cli.ts",
    "./tui": "./tui.ts",
    "./types": "./services/types.ts"
  },
  "license": "Unlicense OR CC0-1.0",
  "publish": {
    "include": [
      "README.md",
      "deno.json",
      "mod.ts",
      "cli.ts",
      "tui.ts",
      "paths.ts",
      "utils.ts",
      "services/**/*.ts",
      "db/**/*.ts",
      "tui/**/*.ts"
    ],
    "exclude": [
      "**/*.test.ts",
      "**/*_test.ts"
    ]
  },
  "tasks": {
    "dev": "deno run -A --watch=static/,routes/ dev.ts",
    "build": "deno run -A dev.ts build",
    "start": "deno run -A main.ts",
    "preview": "deno run -A main.ts",
    "check": "deno check mod.ts cli.ts server.ts tui.ts main.ts dev.ts tui/mod.ts",
    "tui": "deno run -A cli.ts tui"
  },
  "imports": {
    "$fresh/": "https://deno.land/x/fresh@1.7.3/",
    "preact": "https://esm.sh/preact@10.22.0",
    "preact/": "https://esm.sh/preact@10.22.0/",
    "@preact/signals-core": "npm:@preact/signals-core@1.5.1",
    "tailwindcss": "npm:tailwindcss@3.4.7",
    "tailwindcss/": "npm:/tailwindcss@3.4.7/",
    "tailwindcss/plugin": "npm:tailwindcss@3.4.7/plugin.js",
    "sqlite3": "jsr:@db/sqlite@0.13.0",
    "ansi_up": "https://esm.sh/ansi_up@6.0.2",
    "zod": "npm:zod@3.25.76",
    "@garazyk/hamownia": "jsr:@garazyk/hamownia@0.1.0-alpha.1",
    "@garazyk/laweta": "jsr:@garazyk/laweta@0.1.0-alpha.1",
    "@garazyk/schemat": "jsr:@garazyk/schemat@0.1.0-alpha.1",
    "@std/assert": "jsr:@std/assert@1",
    "@std/cli/parse-args": "jsr:@std/cli@1.0.6/parse-args",
    "@std/path": "jsr:@std/path@1",
    "@std/fmt": "jsr:@std/fmt@1",
    "@std/fmt/colors": "jsr:@std/fmt@1/colors"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  }
}
