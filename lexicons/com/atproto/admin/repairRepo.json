{
  "lexicon": 1,
  "id": "com.atproto.admin.repairRepo",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Force re-initialize a repository for a given DID. Admin only.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["did"],
          "properties": {
            "did": {
              "type": "string",
              "format": "did",
              "description": "The DID of the repo to repair"
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["success", "did"],
          "properties": {
            "success": { "type": "boolean" },
            "did": { "type": "string", "format": "did" }
          }
        }
      }
    }
  }
}
