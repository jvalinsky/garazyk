{
  "lexicon": 1,
  "id": "app.bsky.unspecced.confirmAgeAssurance",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Confirm age assurance with a token sent via email.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["token"],
          "properties": {
            "token": { "type": "string" }
          }
        }
      },
      "errors": [
        { "name": "InvalidToken" },
        { "name": "ExpiredToken" }
      ]
    }
  }
}
