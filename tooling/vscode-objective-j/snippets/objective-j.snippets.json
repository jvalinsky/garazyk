{
  "@implementation": {
    "prefix": "@impl",
    "body": [
      "@implementation ${1:ClassName} : ${2:CPObject}",
      "{",
      "    $3",
      "}",
      "",
      "$0",
      "",
      "@end"
    ],
    "description": "Objective-J class implementation"
  },
  "@implementation (no ivars)": {
    "prefix": "@impn",
    "body": [
      "@implementation ${1:ClassName} : ${2:CPObject}",
      "",
      "$0",
      "",
      "@end"
    ],
    "description": "Objective-J class implementation without instance variables"
  },
  "@import framework": {
    "prefix": "@impf",
    "body": "@import <${1:Foundation}/${2:CPObject}.j>",
    "description": "Import a framework class"
  },
  "@import local": {
    "prefix": "@impo",
    "body": "@import \"${1:MyClass}.j\"",
    "description": "Import a local file"
  },
  "@selector": {
    "prefix": "@sel",
    "body": "@selector(${1:methodName:})",
    "description": "Objective-J selector literal"
  },
  "@accessors": {
    "prefix": "@acc",
    "body": "@accessors(property=${1:name})",
    "description": "Property accessors declaration"
  },
  "@protocol": {
    "prefix": "@prot",
    "body": [
      "@protocol ${1:ProtocolName} <${2:CPObject}>",
      "",
      "@required",
      "- (void)${3:requiredMethod};",
      "",
      "@optional",
      "- (void)${4:optionalMethod};",
      "",
      "@end"
    ],
    "description": "Objective-J protocol declaration"
  },
  "Category": {
    "prefix": "@cat",
    "body": [
      "@implementation ${1:ClassName} (${2:CategoryName})",
      "",
      "$0",
      "",
      "@end"
    ],
    "description": "Objective-J category"
  },
  "Instance method": {
    "prefix": "-method",
    "body": [
      "- (${1:void})${2:methodName}",
      "{",
      "    $0",
      "}"
    ],
    "description": "Instance method"
  },
  "Instance method with parameter": {
    "prefix": "-methodp",
    "body": [
      "- (${1:void})${2:methodName}:(${3:id})${4:param}",
      "{",
      "    $0",
      "}"
    ],
    "description": "Instance method with parameter"
  },
  "Class method": {
    "prefix": "+method",
    "body": [
      "+ (${1:id})${2:methodName}",
      "{",
      "    $0",
      "}"
    ],
    "description": "Class method"
  },
  "init method": {
    "prefix": "init",
    "body": [
      "- (id)init",
      "{",
      "    self = [super init];",
      "",
      "    if (self)",
      "    {",
      "        $0",
      "    }",
      "",
      "    return self;",
      "}"
    ],
    "description": "Standard init method"
  },
  "initWith method": {
    "prefix": "initWith",
    "body": [
      "- (id)initWith${1:Parameter}:(${2:id})${3:aParam}",
      "{",
      "    self = [super init];",
      "",
      "    if (self)",
      "    {",
      "        ${4:_param} = ${3:aParam};",
      "    }",
      "",
      "    return self;",
      "}"
    ],
    "description": "Custom init method with parameter"
  },
  "alloc init": {
    "prefix": "alloc",
    "body": "[[${1:ClassName} alloc] init${2}]",
    "description": "Alloc and init an object"
  },
  "Action method": {
    "prefix": "@action",
    "body": [
      "- (@action)${1:actionName}:(id)${2:sender}",
      "{",
      "    $0",
      "}"
    ],
    "description": "Action method (IBAction equivalent)"
  },
  "@outlet": {
    "prefix": "@outlet",
    "body": "${1:CPView} ${2:myView} @accessors;",
    "description": "Outlet instance variable"
  },
  "awakeFromCib": {
    "prefix": "awake",
    "body": [
      "- (void)awakeFromCib",
      "{",
      "    $0",
      "}"
    ],
    "description": "awakeFromCib method"
  },
  "@class": {
    "prefix": "@class",
    "body": "@class ${1:ClassName}",
    "description": "Forward class declaration"
  },
  "@global": {
    "prefix": "@global",
    "body": "@global ${1:VariableName}",
    "description": "Global variable declaration"
  },
  "@typedef": {
    "prefix": "@typedef",
    "body": "@typedef ${1:TypeName}",
    "description": "Type definition"
  },
  "@ref": {
    "prefix": "@ref",
    "body": "@ref(${1:variable})",
    "description": "Reference (pointer analog)"
  },
  "@deref": {
    "prefix": "@deref",
    "body": "@deref(${1:reference})",
    "description": "Dereference"
  },
  "Dictionary literal": {
    "prefix": "@dict",
    "body": [
      "@{",
      "    ${1:@\"key\"}: ${2:value},$0",
      "}"
    ],
    "description": "Objective-J dictionary literal"
  }
}
