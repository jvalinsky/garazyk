{
  "name": "objective-j",
  "displayName": "Objective-J",
  "description": "Objective-J language support for VS Code — syntax highlighting, snippets, code navigation, and completions for the Cappuccino framework's Objective-J language.",
  "version": "0.3.0",
  "publisher": "garazyk",
  "license": "MIT",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#2D2D2D",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Formatters",
    "Linters"
  ],
  "keywords": [
    "objective-j",
    "objj",
    "cappuccino",
    ".j"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jvalinsky/garazyk"
  },
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "objective-j",
        "aliases": [
          "Objective-J",
          "ObjJ",
          "objective-j"
        ],
        "extensions": [
          ".j",
          ".sj"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "objective-j",
        "scopeName": "source.objective-j",
        "path": "./syntaxes/objective-j.tmLanguage.json",
        "embeddedLanguages": {
          "source.js": "javascript"
        }
      }
    ],
    "snippets": [
      {
        "language": "objective-j",
        "path": "./snippets/objective-j.snippets.json"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "package": "npm run compile && vsce package --allow-missing-repository"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.0.0"
  }
}