{
  "comments": {
    "lineComment": "//",
    "blockComment": ["/*", "*/"]
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "'", "close": "'", "notIn": ["string"] },
    { "open": "/*", "close": "*/", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"" },
    { "open": "'", "close": "'" },
    { "open": "<", "close": ">" }
  ],
  "folding": {
    "markers": {
      "start": "^\\s*(@implementation|@protocol|\\{|/\\*|#pragma\\s+mark\\s+-)",
      "end": "^\\s*(@end|\\}|\\*/)"
    }
  },
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(@implementation|@protocol)\\b|.*\\{\\s*$",
    "decreaseIndentPattern": "^\\s*(\\}|@end)\\s*$"
  },
  "wordPattern": "@?[a-zA-Z_][a-zA-Z0-9_]*:?"
}
