{
  "lexicon": 1,
  "id": "com.atproto.server.getAccount",
  "defs": {
    "main": {
      "type": "query",
      "description": "Legacy compatibility endpoint returning the authenticated account object.",
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["did", "handle"],
          "properties": {
            "did": { "type": "string", "format": "did" },
            "handle": { "type": "string", "format": "handle" },
            "email": { "type": "string" },
            "emailConfirmed": { "type": "boolean" }
          }
        }
      }
    }
  }
}
