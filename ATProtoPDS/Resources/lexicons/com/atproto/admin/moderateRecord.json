{
  "lexicon": 1,
  "id": "com.atproto.admin.moderateRecord",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Legacy compatibility endpoint for record moderation decisions.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["uri", "action"],
          "properties": {
            "uri": { "type": "string", "format": "at-uri" },
            "action": { "type": "string" },
            "reason": { "type": "string" },
            "note": { "type": "string" }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["status", "uri", "action", "timestamp"],
          "properties": {
            "status": { "type": "string" },
            "uri": { "type": "string", "format": "at-uri" },
            "action": { "type": "string" },
            "timestamp": { "type": "string", "format": "datetime" }
          }
        }
      }
    }
  }
}
