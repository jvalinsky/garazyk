{
  "workspace": [
    "./packages/docker-client",
    "./packages/atproto-client",
    "./packages/atproto-topology",
    "./packages/scenario-runner",
    "./scripts/scenario-dashboard"
  ],
  "imports": {
    "@std/path": "jsr:@std/path@0.224.0",
    "@std/fmt/colors": "jsr:@std/fmt@0.224.0/colors",
    "@std/fs": "jsr:@std/fs@0.224.0",
    "@std/cli": "jsr:@std/cli@1.0.6",
    "@std/cli/parse-args": "jsr:@std/cli@1.0.6/parse-args",
    "@std/assert": "jsr:@std/assert@0.224.0",
    "@ipld/dag-cbor": "npm:@ipld/dag-cbor@^9.0.0",
    "zod": "npm:zod@^3.22.0",
    "@garazyk/docker-client": "./packages/docker-client/mod.ts",
    "@garazyk/atproto-client": "./packages/atproto-client/mod.ts",
    "@garazyk/atproto-topology": "./packages/atproto-topology/mod.ts",
    "@garazyk/scenario-runner": "./packages/scenario-runner/mod.ts"
  },
  "tasks": {
    "test": "deno test -A packages/",
    "check": "deno check packages/*/mod.ts scripts/*.ts",
    "lint": "deno lint packages/ scripts/",
    "fmt": "deno fmt packages/ scripts/",
    "generate-client": "deno run -A packages/atproto-client/scripts/generate.ts",
    "scenarios": "deno run -A scripts/run_scenarios.ts",
    "dashboard": "cd scripts/scenario-dashboard && deno task dev"
  }
}