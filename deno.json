{
  "workspace": [
    "./packages/laweta",
    "./packages/gruszka",
    "./packages/schemat",
    "./packages/hamownia",
    "./packages/dashboard",
    "./packages/narzedzia"
  ],
  "imports": {
    "@std/path": "jsr:@std/path@0.224.0",
    "@std/fmt/colors": "jsr:@std/fmt@0.224.0/colors",
    "@std/fs": "jsr:@std/fs@0.224.0",
    "@std/cli": "jsr:@std/cli@1.0.6",
    "@std/cli/parse-args": "jsr:@std/cli@1.0.6/parse-args",
    "@std/assert": "jsr:@std/assert@0.224.0",
    "@opentelemetry/api": "npm:@opentelemetry/api@^1.7.0",
    "playwright": "npm:playwright@^1.40.0",
    "@ipld/dag-cbor": "npm:@ipld/dag-cbor@^9.0.0",
    "cborg": "npm:cborg@5.1.1",
    "zod": "npm:zod@^3.22.0"
  },
  "tasks": {
    "check": "deno task boundaries && deno check packages/*/mod.ts scripts/*.ts && deno task dashboard:check",
    "dashboard:check": "deno check --config packages/dashboard/deno.json packages/dashboard/mod.ts packages/dashboard/cli.ts packages/dashboard/server.ts packages/dashboard/tui.ts",
    "boundaries": "deno run --allow-read scripts/dev/check_module_boundaries.ts",
    "lint": "deno lint packages/ scripts/",
    "fmt": "deno fmt packages/ scripts/",
    "build": "deno run -A scripts/build.ts",
    "build:docker-stage": "deno run -A scripts/build.ts docker-stage",
    "test": "deno run -A scripts/test_runner.ts",
    "test:packages": "deno test -A packages/",
    "generate-client": "deno run -A packages/gruszka/scripts/generate.ts",
    "docs:validate": "deno run -A -e 'import { docValidationMain } from \"@garazyk/narzedzia\"; await docValidationMain();'",
    "scenarios": "deno run -A scripts/run_scenarios.ts",
    "demo": "deno run -A scripts/demo.ts",
    "service": "deno run -A scripts/manage_services.ts",
    "service:status": "deno task service status",
    "service:stop": "deno task service stop",
    "service:reseed": "deno task service reseed",
    "ops": "deno run -A scripts/ops.ts",
    "fuzz": "deno run -A scripts/fuzz.ts",
    "dashboard": "cd packages/dashboard && deno task dev",
    "dashboard:tui": "cd packages/dashboard && deno task tui"
  }
}
