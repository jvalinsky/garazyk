{
  "workspace": [
    "./packages/laweta",
    "./packages/gruszka",
    "./packages/schemat",
    "./packages/hamownia",
    "./packages/narzedzia",
    "./packages/tui",
    "./scripts/scenario-dashboard"
  ],
  "imports": {
    "@std/yaml": "jsr:@std/yaml@0.224.0",
    "@std/path": "jsr:@std/path@0.224.0",
    "@std/fmt/colors": "jsr:@std/fmt@0.224.0/colors",
    "@std/fs": "jsr:@std/fs@0.224.0",
    "@std/cli": "jsr:@std/cli@1.0.6",
    "@std/cli/parse-args": "jsr:@std/cli@1.0.6/parse-args",
    "@std/assert": "jsr:@std/assert@0.224.0",
    "@std/async": "jsr:@std/async@0.224.1",
    "@opentelemetry/api": "npm:@opentelemetry/api@^1.7.0",
    "@std/streams": "jsr:@std/streams@^1.1.0",
    "playwright": "npm:playwright@1.52.0",
    "@ipld/dag-cbor": "npm:@ipld/dag-cbor@^9.0.0",
    "cborg": "npm:cborg@5.1.1",
    "zod": "npm:zod@^3.22.0",
    "preact": "https://esm.sh/preact@10.22.0",
    "preact/": "https://esm.sh/preact@10.22.0/",
    "@preact/signals": "https://esm.sh/*@preact/signals@1.2.3",
    "@preact/signals-core": "https://esm.sh/*@preact/signals-core@1.5.1",
    "@garazyk/laweta": "./packages/laweta/mod.ts",
    "@garazyk/laweta/": "./packages/laweta/",
    "@garazyk/hamownia": "./packages/hamownia/mod.ts",
    "@garazyk/hamownia/": "./packages/hamownia/",
    "@garazyk/gruszka": "./packages/gruszka/mod.ts",
    "@garazyk/gruszka/": "./packages/gruszka/",
    "@garazyk/gruszka/lexicon-resolution": "./packages/gruszka/lexicon_resolution/mod.ts",
    "@garazyk/schemat": "./packages/schemat/mod.ts",
    "@garazyk/narzedzia": "./packages/narzedzia/mod.ts",
    "@garazyk/tui": "./packages/tui/mod.ts",
    "@garazyk/tui/testing": "./packages/tui/testing/mod.ts",
    "@garazyk/tui/testing/": "./packages/tui/testing/",
    "@cliffy/command": "jsr:@cliffy/command@^1.1.0",
    "@cliffy/prompt": "jsr:@cliffy/prompt@^1.1.0",
    "@cliffy/table": "jsr:@cliffy/table@^1.1.0"
  },
  "lint": {
    "exclude": ["packages/gruszka/lexicons.ts"]
  },
  "tasks": {
    "check": "deno check packages/*/mod.ts",
    "lint": "deno lint packages/ --ignore=packages/gruszka/lexicons.ts",
    "fmt": "deno fmt packages/",
    "test": "deno test -A packages/",
    "generate-client": "deno run -A packages/gruszka/scripts/generate.ts",
    "hamownia": "deno run -A packages/hamownia/cli.ts",
    "narzedzia": "deno run -A packages/narzedzia/cli.ts",
    "dashboard:dev": "cd scripts/scenario-dashboard && deno task dev",
    "dashboard:dev:agent": "cd scripts/scenario-dashboard && deno task dev:agent",
    "dashboard:tui": "cd scripts/scenario-dashboard && deno task tui"
  }
}
