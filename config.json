{
  "server": {
    "host": "0.0.0.0",
    "port": 8080,
    "data_dir": "./data"
  },
  "plc": {
    "url": "mock",
    "retry_count": 3,
    "retry_delay_ms": 1000
  },
  "debug": {
    "skip_plc_operations": true,
    "verbose_logging": true,
    "in_memory_databases": false,
    "reset_on_startup": false
  },
  "database": {
    "user_pool_max_size": 100,
    "service_pool_max_size": 10,
    "did_cache_pool_max_size": 1000,
    "sequencer_pool_max_size": 100
  },
  "session": {
    "access_token_ttl_seconds": 3600,
    "refresh_token_ttl_seconds": 604800,
    "invite_code_required": false
  },
  "rate_limit": {
    "enabled": true,
    "requests_per_minute": 1000,
    "burst_size": 100
  }
}