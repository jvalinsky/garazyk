{
  "lexicon": 1,
  "id": "app.bsky.draft.createDraft",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Create a draft post.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "properties": {
            "text": { "type": "string" },
            "langs": {
              "type": "array",
              "items": { "type": "string", "format": "language" }
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "properties": {
            "uri": { "type": "string", "format": "at-uri" }
          }
        }
      }
    }
  }
}
