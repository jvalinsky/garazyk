{
  "lexicon": 1,
  "id": "chat.bsky.group.getMessages",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get group messages",
      "parameters": {
        "type": "params",
        "required": ["groupUri"],
        "properties": {
          "groupUri": { "type": "string" },
          "limit": { "type": "integer" },
          "cursor": { "type": "string" }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "properties": {
            "messages": { "type": "array", "items": { "type": "object" } },
            "cursor": { "type": "string" }
          }
        }
      }
    }
  }
}
