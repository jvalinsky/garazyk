{
  "lexicon": 1,
  "id": "com.atproto.admin.queryAuditLog",
  "defs": {
    "main": {
      "type": "query",
      "description": "Query the admin audit log for actions taken by administrators.",
      "parameters": {
        "type": "params",
        "properties": {
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 50
          },
          "cursor": { "type": "string" },
          "adminDid": { "type": "string", "format": "did" }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["events"],
          "properties": {
            "cursor": { "type": "string" },
            "events": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "com.atproto.admin.defs#auditLogEvent"
              }
            }
          }
        }
      }
    }
  }
}
