{
  "lexicon": 1,
  "id": "com.atproto.admin.getBlobAuditStatus",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get the status of a blob audit job. Admin only.",
      "parameters": {
        "type": "params",
        "required": ["jobId"],
        "properties": {
          "jobId": {
            "type": "string",
            "description": "The ID of the audit job"
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["jobId"],
          "properties": {
            "jobId": { "type": "string" },
            "status": { "type": "string" },
            "progress": { "type": "integer" },
            "totalBlobs": { "type": "integer" },
            "processedBlobs": { "type": "integer" },
            "errorCount": { "type": "integer" }
          }
        }
      }
    }
  }
}
