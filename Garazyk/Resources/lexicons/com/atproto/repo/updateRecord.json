{
  "lexicon": 1,
  "id": "com.atproto.repo.updateRecord",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Legacy compatibility endpoint to update an existing repository record.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["collection", "rkey", "record"],
          "properties": {
            "collection": { "type": "string", "format": "nsid" },
            "rkey": { "type": "string" },
            "record": { "type": "unknown" },
            "validate": { "type": "boolean" }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": { "type": "unknown" }
      }
    }
  }
}
