{
  "lexicon": 1,
  "id": "com.germnetwork.mailbox.claimAddresses",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Claim a batch of ephemeral mailbox addresses for E2EE message delivery. Addresses are opaque strings assigned to agents (not DIDs) to protect metadata. Models after Germ's current shipping 1:1 E2EE DM product.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["agentRef", "count"],
          "properties": {
            "agentRef": {
              "type": "string",
              "description": "Opaque agent reference (not a DID)",
              "minLength": 1,
              "maxLength": 256
            },
            "count": {
              "type": "integer",
              "description": "Number of addresses to claim (1-100)",
              "minimum": 1,
              "maximum": 100
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["addresses"],
          "properties": {
            "addresses": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 128
              },
              "description": "Array of claimed opaque mailbox addresses"
            }
          }
        }
      }
    }
  }
}
