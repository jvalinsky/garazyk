{
  "lexicon": 1,
  "id": "tools.ozone.server.updateConfig",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Update Ozone server configuration settings.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "properties": {
            "settings": {
              "type": "object",
              "description": "Key-value pairs of configuration settings to update"
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["success"],
          "properties": {
            "success": { "type": "boolean" }
          }
        }
      }
    }
  }
}
