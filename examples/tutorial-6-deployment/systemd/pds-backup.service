[Unit]
Description=ATProto PDS Backup Service
After=docker.service
Requires=docker.service

[Service]
Type=oneshot
User=root
WorkingDirectory=/opt/atprotopds-deploy
ExecStart=/opt/atprotopds-deploy/scripts/backup.sh
StandardOutput=journal
StandardError=journal

# Security hardening
PrivateTmp=yes
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
ReadWritePaths=/var/backups/atprotopds /var/lib/docker/volumes

[Install]
WantedBy=multi-user.target
