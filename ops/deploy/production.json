{
  "server": {
    "host": "0.0.0.0",
    "port": 8080,
    "data_dir": "/var/lib/atprotopds/data"
  },
  "plc": {
    "url": "https://plc.directory",
    "retry_count": 5,
    "retry_delay_ms": 2000
  },
  "debug": {
    "verbose_logging": false,
    "in_memory_databases": false,
    "reset_on_startup": false,
    "use_new_repository": false
  },
  "database": {
    "user_pool_max_size": 200,
    "service_pool_max_size": 20,
    "did_cache_pool_max_size": 5000,
    "sequencer_pool_max_size": 200
  },
  "session": {
    "access_token_ttl_seconds": 1800,
    "refresh_token_ttl_seconds": 2592000,
    "invite_code_required": true
  },
  "phone_verification": {
    "provider": "none"
  },
  "rate_limit": {
    "enabled": true,
    "requests_per_minute": 300,
    "burst_size": 50,
    "did_limit": 3000,
    "did_window": 3600,
    "ip_limit": 300,
    "ip_window": 60,
    "blob_limit": 25,
    "blob_window": 3600
  },
  "ssl_pinning": {
    "enabled": true
  },
  "logging": {
    "file_path": "/var/log/atprotopds/pds.log",
    "level": "info",
    "format": "json",
    "max_file_size_mb": 50,
    "max_files": 10,
    "async": true
  },
  "nodeinfo": {
    "enabled": true,
    "software_name": "atprotopds",
    "software_version": "1.0.0",
    "repository_url": "https://github.com/jvalinsky/NSPds",
    "homepage_url": "https://github.com/jvalinsky/NSPds",
    "open_registrations": false
  }
}
