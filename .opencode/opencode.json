{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "./plugin/garazyk-pty.ts"
  ],
  "mcp": {
    "garazyk-tui": {
      "type": "local",
      "command": ["deno", "run", "-A", "scripts/mcp-tui/server.ts"],
      "enabled": true
    },
    "garazyk-pty": {
      "type": "local",
      "command": ["node", "scripts/mcp-pty/server.mjs"],
      "enabled": true,
      "env": {
        "GARAZYK_PTY_MCP_ALLOW": "/opt/homebrew/bin/ttysolitaire"
      }
    }
  }
}
