{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": "# Protocols and Exception Handling — Full Test\n\nAll features: `@protocol` (name + method-level), `@try/@catch/@finally`, `@throw`/`@throw;` (re-throw)."
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "/* ── Part 1: @protocol with @required and @optional ──────────── */\n",
    "@protocol Scrollable\n",
    "@required\n",
    "- (void)scrollToTop;\n",
    "- (int)currentOffset;\n",
    "@optional\n",
    "- (void)scrollToBottom;\n",
    "@end\n",
    "NSLog(@\"Protocol Scrollable registered (required=%u)\", (unsigned int)1);"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "/* ── Part 2: @interface with <Protocol> conformance ───────────── */\n",
    "@interface MyView : NSObject <Scrollable>\n",
    "- (void)scrollToTop;\n",
    "- (int)currentOffset;\n",
    "@end\n",
    "\n",
    "@implementation MyView\n",
    "- (void)scrollToTop {\n",
    "    NSLog(@\"MyView: scrolling to top\");\n",
    "}\n",
    "- (int)currentOffset {\n",
    "    return 42;\n",
    "}\n",
    "@end\n",
    "\n",
    "MyView *v = [[MyView alloc] init];\n",
    "[v scrollToTop];\n",
    "NSLog(@\"offset=%d\", [v currentOffset]);"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "/* ── Part 3: conformsToProtocol: check ─────────────────────────── */\n",
    "BOOL conforms = [v conformsToProtocol:@\"Scrollable\"];\n",
    "NSLog(@\"v conforms to Scrollable: %d\", (int)conforms);"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": "## Part 4: @try / @catch / @finally"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "/* Basic @try/@catch/@finally */\n",
    "BOOL caught = NO;\n",
    "@try {\n",
    "    NSLog(@\"Inside try\");\n",
    "    @throw @\"oops\";\n",
    "    NSLog(@\"Should not reach here\");\n",
    "}\n",
    "@catch (id e) {\n",
    "    caught = YES;\n",
    "    NSLog(@\"Caught: %@\", e);\n",
    "}\n",
    "@finally {\n",
    "    NSLog(@\"Finally always runs\");\n",
    "}\n",
    "NSLog(@\"caught=%d\", (int)caught);"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "/* @try with no exception — finally still runs */\n",
    "BOOL finallyRan = NO;\n",
    "@try {\n",
    "    NSLog(@\"No exception here\");\n",
    "}\n",
    "@catch (id e) {\n",
    "    NSLog(@\"Should not reach: %@\", e);\n",
    "}\n",
    "@finally {\n",
    "    finallyRan = YES;\n",
    "    NSLog(@\"Finally after clean try\");\n",
    "}\n",
    "NSLog(@\"finallyRan=%d\", (int)finallyRan);"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": "## Part 5: @throw; (re-throw)"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "/* @throw; re-throws the current exception */\n",
    "@try {\n",
    "    @try {\n",
    "        NSLog(@\"Inner: throwing\");\n",
    "        @throw @\"inner error\";\n",
    "    }\n",
    "    @catch (id e) {\n",
    "        NSLog(@\"Outer catch: re-throwing %@\", e);\n",
    "        @throw; /* re-throw */\n",
    "    }\n",
    "}\n",
    "@catch (id e) {\n",
    "    NSLog(@\"Caught re-throw: %@\", e);\n",
    "}\n",
    "@finally {\n",
    "    NSLog(@\"Cleanup\");\n",
    "}"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": "## Part 6: Uncaught exception → ObjCException error"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "/* Uncaught @throw produces an ObjCException error in Jupyter. */\n",
    "/* We wrap in @try to verify the exception value. */\n",
    "@try {\n",
    "    @throw @\"Uncaught!\";\n",
    "    NSLog(@\"Should not reach\");\n",
    "} @catch (id e) {\n",
    "    NSLog(@\"Caught uncaught: %@\", e);\n",
    "}\n"
   ]
  }
 ],
